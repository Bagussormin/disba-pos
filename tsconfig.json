{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": false,
    "allowJs": true,
    "esModuleInterop": true
  },
  "include": [
    "App.tsx",
    "index.tsx",
    "types.ts",
    "components/**/*.tsx",
    "components/**/*.ts",
    "services/**/*.ts",
    "lib/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
